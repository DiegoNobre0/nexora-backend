// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("MASTER_DATABASE_URL")
}

// ------------------------------------------------------
// 1. PLANOS (Os pacotes que o Nexora vai vender)
// ------------------------------------------------------
model Plan {
  id            String   @id @default(uuid())
  name          String   // Ex: "Basic", "Pro", "Enterprise"
  price         Decimal  @db.Decimal(10, 2)
  max_employees Int      @default(1)
  features      Json?    // Estrutura flexível para flags (ex: { "has_ai": true, "has_whatsapp": true })
  is_active     Boolean  @default(true)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  subscriptions Subscription[]

  @@map("plans")
}

// ------------------------------------------------------
// 2. EMPRESAS (Os salões, barbearias e clínicas)
// ------------------------------------------------------
model Company {
  id             String   @id @default(uuid())
  name           String
  slug           String   @unique // Para URLs amigáveis (ex: nexora.com/barbearia-do-ze)
  tenant_db_name String   @unique // O NOME DA BASE DE DADOS ISOLADA DESTA EMPRESA (Crucial para a arquitetura)
  document       String?  @unique // NIF / CNPJ
  is_active      Boolean  @default(true)
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  users         User[]
  subscriptions Subscription[]

  @@map("companies")
}

// ------------------------------------------------------
// 3. UTILIZADORES (Os donos e gestores das empresas)
// ------------------------------------------------------
model User {
  id            String   @id @default(uuid())
  company_id    String
  name          String
  email         String   @unique
  password_hash String
  role          Role     @default(OWNER)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  company Company @relation(fields: [company_id], references: [id], onDelete: Cascade)

  @@map("users")
}

// ------------------------------------------------------
// 4. ASSINATURAS (A ligação entre a Empresa e o Plano)
// ------------------------------------------------------
model Subscription {
  id                   String             @id @default(uuid())
  company_id           String
  plan_id              String
  status               SubscriptionStatus @default(TRIALING)
  current_period_start DateTime
  current_period_end   DateTime
  gateway_customer_id  String?            // ID do cliente no Stripe/Asaas/MercadoPago
  gateway_sub_id       String?            // ID da assinatura no gateway de pagamento
  created_at           DateTime           @default(now())
  updated_at           DateTime           @updatedAt

  company Company @relation(fields: [company_id], references: [id], onDelete: Cascade)
  plan    Plan    @relation(fields: [plan_id], references: [id], onDelete: Restrict)

  @@map("subscriptions")
}

// ------------------------------------------------------
// ENUMS (Tipos fixos de dados)
// ------------------------------------------------------
enum Role {
  SUPERADMIN // A sua equipa (Administradores do Nexora)
  OWNER      // Dono do salão/clínica
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  INCOMPLETE
}