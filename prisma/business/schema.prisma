// prisma/business/business.prisma

generator businessClient { 
  provider = "prisma-client-js"
  output   = "../../node_modules/@prisma/business-client"
}


datasource businessdb { 
  provider = "postgresql"
  url      = env("TENANT_DATABASE_URL") 
}

// ------------------------------------------------------
// 1. CLIENTES (CRM)
// ------------------------------------------------------
model Client {
  id         String   @id @default(uuid())
  name       String
  phone      String   @unique
  birth_date DateTime?
  notes      String?  @businessdb.Text
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  calendars Calendar[]

  @@map("clients")
}

// ------------------------------------------------------
// 2. PROFISSIONAIS (Equipe)
// ------------------------------------------------------
model Employee {
  id         String   @id @default(uuid())
  name       String
  phone      String?
  is_active  Boolean  @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  services     EmployeeService[]
  calendars Calendar[]

  @@map("employees")
}

// ------------------------------------------------------
// 3. SERVIÇOS
// ------------------------------------------------------
model Service {
  id               String   @id @default(uuid())
  name             String
  description      String? @businessdb.Text
  price            Decimal  @businessdb.Decimal(10, 2)
  duration_minutes Int      
  is_active        Boolean  @default(true)

  employees    EmployeeService[]
  calendars Calendar[]

  @@map("services")
}

// ------------------------------------------------------
// 4. RELAÇÃO PROFISSIONAL <-> SERVIÇO (Comissões)
// ------------------------------------------------------
model EmployeeService {
  employee_id           String
  service_id            String
  commission_percentage Decimal @businessdb.Decimal(5, 2) 

  employee Employee @relation(fields: [employee_id], references: [id], onDelete: Cascade)
  service  Service  @relation(fields: [service_id], references: [id], onDelete: Cascade)

  @@id([employee_id, service_id])
  @@map("employee_services")
}

// ------------------------------------------------------
// 5. Calendar (O coração do sistema)
// ------------------------------------------------------
model Calendar {
  id          String            @id @default(uuid())
  client_id   String
  employee_id String
  service_id  String
  start_time  DateTime
  end_time    DateTime
  status      CalendarStatus @default(PENDING)
  notes       String? @businessdb.Text
  created_at  DateTime          @default(now())
  updated_at  DateTime          @updatedAt

  client   Client   @relation(fields: [client_id], references: [id])
  employee Employee @relation(fields: [employee_id], references: [id])
  service  Service  @relation(fields: [service_id], references: [id])

  @@map("appointments")
}

// ------------------------------------------------------
// 6. CONFIGURAÇÕES (WhatsApp e IA da Empresa)
// ------------------------------------------------------
model Config {
  id               String  @id @default(uuid())
  whatsapp_number  String?
  whatsapp_session String? 
  ai_prompt        String? @businessdb.Text 
  auto_reply       Boolean @default(true) 

  @@map("configs")
}

// ------------------------------------------------------
// ENUMS
// ------------------------------------------------------
enum CalendarStatus {
  PENDING   
  CONFIRMED 
  COMPLETED 
  CANCELED  
  NO_SHOW   
}